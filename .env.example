# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Assigned on hackathon day by organisers
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@<cluster-url>/<database>?retryWrites=true&w=majority&appName=<appName>

# ── VoyageAI Embeddings ───────────────────────────────────────────────────────
# Assigned on hackathon day — used for MongoDB Atlas Vector Search
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AWS Bedrock (Claude via Bedrock) ─────────────────────────────────────────
# Assigned on hackathon day by AWS/infra team
AWS_ACCESS_KEY_ID=AKIA_PLACEHOLDER
AWS_SECRET_ACCESS_KEY=PLACEHOLDER
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# ── LangSmith tracing (optional) ─────────────────────────────────────────────
LANGCHAIN_API_KEY=ls__
LANGCHAIN_PROJECT=mongaccentic
LANGCHAIN_TRACING_V2=true
